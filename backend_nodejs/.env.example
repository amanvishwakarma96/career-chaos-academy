# Career Chaos Academy backend development configuration
# Copy to .env for reference, but note that the current dependency-free server
# reads process environment variables directly. Use your shell, IDE, Docker,
# or process manager to load these values.

NODE_ENV=development
HOST=0.0.0.0
PORT=5085

# Development placeholders only. Replace before any shared or deployed use.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe@123
ADMIN_TOKEN_SECRET=replace-with-a-long-random-secret
ADMIN_TOKEN_TTL_MINUTES=120

# Request and abuse controls
MAX_BODY_BYTES=1048576
MAX_STORED_TEXT_LENGTH=2000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# Monitoring and retention prototypes
CRASH_MONITORING_ENABLED=true
RETENTION_DAYS=365
